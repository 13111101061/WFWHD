{
  "$schema": "ProviderManifest/v2",
  "providerKey": "minimax",
  "provider": {
    "displayName": "MiniMax",
    "description": "MiniMax AI 语音服务",
    "status": "beta",
    "protocolTypes": [
      "http"
    ],
    "credentialMode": "apiKey"
  },
  "services": {
    "minimax_tts": {
      "displayName": "MiniMax TTS",
      "description": "MiniMax 语音合成",
      "aliases": [
        "minimax"
      ],
      "protocol": "http",
      "supportsStreaming": false,
      "supportsAsync": false,
      "apiStructure": "flat",
      "api": {
        "endpoint": "https://api.minimax.chat/v1/text_to_speech",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer ${credential.apiKey}",
          "Content-Type": "application/json"
        },
        "bodyTemplate": {
          "model": "${params.model}",
          "text": "${text}",
          "voice_setting": "${params.voice_setting}",
          "audio_setting": "${params.audio_setting}"
        },
        "responseMapping": {
          "audioPath": "audio",
          "audioEncoding": "binary"
        },
        "timeoutMs": 30000
      },
      "parameters": {
        "voice": {
          "status": "locked",
          "source": "providerVoiceId",
          "mapTo": "voice_setting.voice_id"
        },
        "text": {
          "status": "required",
          "mapTo": "text"
        },
        "emotion": {
          "default": "neutral",
          "values": ["neutral", "happy", "sad", "angry", "fearful"],
          "mapTo": "voice_setting.emotion"
        },
        "format": {
          "default": "mp3",
          "mapTo": "audio_setting.format"
        },
        "sampleRate": {
          "default": 32000,
          "values": [16000, 24000, 32000],
          "mapTo": "audio_setting.sample_rate"
        },
        "speed": {
          "default": 1,
          "range": [0.1, 2],
          "mapTo": "voice_setting.speed"
        },
        "pitch": {
          "default": 0,
          "range": [-12, 12],
          "mapTo": "voice_setting.pitch"
        },
        "volume": {
          "default": 1,
          "range": [0, 1],
          "mapTo": "voice_setting.vol"
        },
        "model": {
          "default": "speech-01-hd-preview",
          "mapTo": "model"
        }
      }
    }
  },
  "voiceCode": {
    "providerCode": "005",
    "serviceKey": "tts"
  }
}