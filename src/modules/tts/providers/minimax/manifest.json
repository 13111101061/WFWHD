{
  "$schema": "ProviderManifest/v2",
  "providerKey": "minimax",
  "provider": {
    "displayName": "MiniMax",
    "description": "MiniMax AI 语音服务",
    "status": "beta",
    "protocolTypes": [
      "http"
    ],
    "credentialMode": "apiKey"
  },
  "services": {
    "minimax_tts": {
      "displayName": "MiniMax TTS",
      "description": "MiniMax 语音合成",
      "aliases": [
        "minimax"
      ],
      "protocol": "http",
      "supportsStreaming": false,
      "supportsAsync": false,
      "apiStructure": "flat",
      "capabilities": {
        "streaming": false,
        "realtime": false,
        "emotion": true,
        "speedAdjustable": true,
        "pitchAdjustable": true,
        "volumeAdjustable": true
      },
      "lockedParams": [
        "voice",
        "model"
      ],
      "parameters": {
        "voice": {
          "status": "locked",
          "source": "providerVoiceId",
          "mapTo": "voice_id"
        },
        "text": {
          "status": "required",
          "mapTo": "text"
        },
        "emotion": {
          "default": "neutral",
          "values": [
            "neutral",
            "happy",
            "sad",
            "angry",
            "fearful"
          ],
          "mapTo": "emotion"
        },
        "format": {
          "default": "mp3",
          "mapTo": "audio_format"
        },
        "sampleRate": {
          "default": 32000,
          "values": [
            16000,
            24000,
            32000
          ],
          "mapTo": "sample_rate"
        },
        "speed": {
          "default": 1,
          "range": [
            0.1,
            2
          ],
          "mapTo": "speed"
        },
        "pitch": {
          "default": 0,
          "range": [
            -12,
            12
          ],
          "mapTo": "pitch"
        },
        "volume": {
          "default": 1,
          "range": [
            0,
            1
          ],
          "mapTo": "volume"
        },
        "model": {
          "default": "speech-01-hd-preview",
          "mapTo": "model"
        }
      },
      "adapter": "./MinimaxTtsAdapter.js"
    }
  },
  "voiceCode": {
    "providerCode": "005",
    "serviceKey": "tts"
  }
}