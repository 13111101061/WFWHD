{
  "$schema": "ProviderManifest/v2",
  "providerKey": "aliyun",
  "provider": {
    "displayName": "阿里云",
    "description": "阿里云智能语音服务",
    "status": "stable",
    "protocolTypes": [
      "http"
    ],
    "credentialMode": "apiKey"
  },
  "services": {
    "aliyun_cosyvoice": {
      "displayName": "阿里云 CosyVoice",
      "description": "阿里云 CosyVoice 语音合成",
      "aliases": [
        "cosyvoice"
      ],
      "protocol": "http",
      "supportsStreaming": true,
      "supportsAsync": true,
      "apiStructure": "flat",
      "capabilities": {
        "streaming": true,
        "realtime": true,
        "emotion": false,
        "speedAdjustable": true,
        "pitchAdjustable": true,
        "volumeAdjustable": true
      },
      "lockedParams": [
        "voice",
        "model"
      ],
      "parameters": {
        "voice": {
          "status": "locked",
          "source": "providerVoiceId",
          "mapTo": "voice"
        },
        "text": {
          "status": "required",
          "mapTo": "text"
        },
        "speed": {
          "default": 1,
          "range": [
            0.5,
            2
          ],
          "mapTo": "rate"
        },
        "pitch": {
          "default": 1,
          "range": [
            0.5,
            1.5
          ],
          "mapTo": "pitch"
        },
        "volume": {
          "default": 50,
          "range": [
            0,
            100
          ],
          "mapTo": "volume"
        },
        "format": {
          "default": "mp3",
          "values": [
            "mp3",
            "wav",
            "pcm",
            "flac"
          ],
          "mapTo": "format"
        },
        "sampleRate": {
          "default": 22050,
          "values": [
            8000,
            16000,
            22050,
            24000
          ],
          "mapTo": "sample_rate"
        },
        "model": {
          "default": "cosyvoice-v1",
          "mapTo": "model"
        }
      },
      "adapter": "./AliyunCosyVoiceAdapter.js"
    },
    "aliyun_qwen_http": {
      "displayName": "阿里云 Qwen HTTP",
      "description": "阿里云通义千问语音合成 HTTP 接口",
      "aliases": [
        "aliyun_qwen",
        "qwen_http"
      ],
      "protocol": "http",
      "supportsStreaming": false,
      "supportsAsync": false,
      "apiStructure": "nested",
      "basePath": "input",
      "capabilities": {
        "streaming": false,
        "realtime": false,
        "emotion": false,
        "speedAdjustable": false,
        "pitchAdjustable": false,
        "volumeAdjustable": false
      },
      "defaultVoiceId": "aliyun-qwen_http-cherry",
      "lockedParams": [
        "voice",
        "model"
      ],
      "parameters": {
        "voice": {
          "status": "locked",
          "source": "providerVoiceId",
          "mapTo": "input.voice"
        },
        "text": {
          "status": "required",
          "mapTo": "input.text"
        },
        "model": {
          "default": "qwen3-tts-instruct-flash",
          "mapTo": "model"
        },
        "languageType": {
          "default": "Auto",
          "values": [
            "Auto",
            "Chinese",
            "English",
            "Japanese",
            "Korean",
            "German",
            "French",
            "Spanish",
            "Russian",
            "Italian",
            "Portuguese"
          ],
          "mapTo": "input.language_type"
        },
        "format": {
          "default": "wav",
          "mapTo": "input.format"
        },
        "sampleRate": {
          "default": 24000,
          "values": [
            8000,
            16000,
            24000,
            48000
          ],
          "mapTo": "input.sample_rate"
        }
      },
      "adapter": "./AliyunQwenAdapter.js"
    }
  },
  "voiceCode": {
    "providerCode": "002",
    "serviceKey": "qwen_http"
  }
}