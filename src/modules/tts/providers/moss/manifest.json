{
  "$schema": "ProviderManifest/v2",
  "providerKey": "moss",
  "provider": {
    "displayName": "MOSS",
    "description": "MOSS 语音合成服务",
    "status": "beta",
    "protocolTypes": [
      "http"
    ],
    "credentialMode": "apiKey"
  },
  "services": {
    "moss_tts": {
      "displayName": "MOSS TTS",
      "description": "MOSS 语音合成服务",
      "aliases": [
        "moss"
      ],
      "protocol": "http",
      "supportsStreaming": false,
      "supportsAsync": false,
      "apiStructure": "flat",
      "defaultVoiceId": "moss-tts-beijingnan",
      "api": {
        "endpoint": "https://studio.mosi.cn/api/v1/audio/speech",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer ${credential.apiKey}",
          "Content-Type": "application/json"
        },
        "bodyTemplate": {
          "model": "${params.model}",
          "text": "${text}",
          "voice_id": "${params.voice_id}",
          "expected_duration_sec": "${params.expected_duration_sec}",
          "sampling_params": "${params.sampling_params}",
          "meta_info": true
        },
        "responseMapping": {
          "audioPath": "audio_data",
          "audioEncoding": "base64"
        },
        "timeoutMs": 30000
      },
      "parameters": {
        "voice": {
          "status": "locked",
          "source": "providerVoiceId",
          "mapTo": "voice_id"
        },
        "text": {
          "status": "required",
          "mapTo": "text"
        },
        "model": {
          "status": "locked",
          "lockedValue": "moss-tts",
          "mapTo": "model"
        },
        "format": {
          "default": "wav",
          "mapTo": "format"
        },
        "sampleRate": {
          "default": 24000,
          "values": [
            16000,
            24000
          ],
          "mapTo": "sample_rate"
        },
        "expectedDurationSec": {
          "ui": {
            "highlight": true
          },
          "mapTo": "expected_duration_sec"
        },
        "samplingParams": {
          "ui": {
            "collapsed": true
          },
          "nested": {
            "temperature": {
              "default": 1.7,
              "range": [
                0.1,
                3
              ],
              "mapTo": "sampling_params.temperature"
            },
            "topP": {
              "default": 0.8,
              "range": [
                0,
                1
              ],
              "mapTo": "sampling_params.top_p"
            },
            "topK": {
              "default": 25,
              "range": [
                1,
                100
              ],
              "mapTo": "sampling_params.top_k"
            },
            "maxNewTokens": {
              "default": 20000,
              "mapTo": "sampling_params.max_new_tokens"
            }
          }
        }
      }
    }
  },
  "voiceCode": {
    "providerCode": "001",
    "serviceKey": "tts"
  },
  "executionPolicy": {
    "timeoutMs": 30000,
    "retryTimes": 1,
    "rateLimit": {
      "maxRequests": 30,
      "windowMs": 60000
    },
    "circuitBreaker": {
      "failureThreshold": 5,
      "successThreshold": 2,
      "timeout": 60000
    }
  }
}