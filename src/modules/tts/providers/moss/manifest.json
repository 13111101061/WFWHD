{
  "$schema": "ProviderManifest/v2",
  "providerKey": "moss",
  "provider": {
    "displayName": "MOSS",
    "description": "MOSS 语音合成服务",
    "status": "beta",
    "protocolTypes": [
      "http"
    ],
    "credentialMode": "apiKey"
  },
  "services": {
    "moss_tts": {
      "displayName": "MOSS TTS",
      "description": "MOSS 语音合成服务",
      "aliases": [
        "moss"
      ],
      "protocol": "http",
      "supportsStreaming": false,
      "supportsAsync": false,
      "apiStructure": "flat",
      "defaultVoiceId": "moss-tts-beijingnan",
      "api": {
        "endpoint": "https://studio.mosi.cn/api/v1/audio/speech",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer ${credential.apiKey}",
          "Content-Type": "application/json"
        },
        "bodyTemplate": {
          "model": "${params.model}",
          "text": "${text}",
          "voice_id": "${params.voice_id}",
          "expected_duration_sec": "${params.expected_duration_sec}",
          "sampling_params": "${params.sampling_params}",
          "meta_info": true
        },
        "responseMapping": {
          "audioPath": "audio_data",
          "audioEncoding": "base64"
        },
        "timeoutMs": 30000
      },
      "parameters": {
        "voice": {
          "status": "locked",
          "source": "providerVoiceId",
          "mapTo": "voice_id"
        },
        "text": {
          "status": "required",
          "mapTo": "text"
        },
        "model": {
          "status": "locked",
          "lockedValue": "moss-tts",
          "mapTo": "model"
        },
        "format": {
          "default": "wav",
          "mapTo": "format"
        },
        "sampleRate": {
          "default": 24000,
          "values": [
            16000,
            24000
          ],
          "mapTo": "sample_rate"
        }
      },
      "customFields": {
        "expectedDurationSec": {
          "displayName": "期望时长",
          "description": "期望生成的语音时长（秒）",
          "type": "number",
          "category": "advanced",
          "default": 5,
          "range": [0.5, 300],
          "mapTo": "expected_duration_sec",
          "ui": {
            "group": "advanced",
            "order": 1,
            "inputType": "number",
            "highlight": true,
            "unit": "秒"
          }
        },
        "samplingParams": {
          "displayName": "采样参数",
          "description": "高级采样参数配置（topP, temperature 等）",
          "type": "object",
          "category": "advanced",
          "mapTo": "sampling_params",
          "ui": {
            "group": "advanced",
            "order": 2,
            "collapsed": true
          },
          "nestedFields": {
            "temperature": {
              "displayName": "Temperature",
              "description": "采样温度",
              "type": "number",
              "default": 1.7,
              "range": [0.1, 3.0],
              "mapTo": "sampling_params.temperature"
            },
            "topP": {
              "displayName": "Top P",
              "description": "核采样参数",
              "type": "number",
              "default": 0.8,
              "range": [0, 1.0],
              "mapTo": "sampling_params.top_p"
            },
            "topK": {
              "displayName": "Top K",
              "description": "Top-K 采样参数",
              "type": "number",
              "default": 25,
              "range": [1, 100],
              "mapTo": "sampling_params.top_k"
            },
            "maxNewTokens": {
              "displayName": "Max New Tokens",
              "description": "最大生成令牌数",
              "type": "number",
              "default": 20000,
              "mapTo": "sampling_params.max_new_tokens"
            }
          }
        }
      }
    }
  },
  "voiceCode": {
    "providerCode": "001",
    "serviceKey": "tts"
  },
  "executionPolicy": {
    "timeoutMs": 30000,
    "retryTimes": 1,
    "rateLimit": {
      "maxRequests": 30,
      "windowMs": 60000
    },
    "circuitBreaker": {
      "failureThreshold": 5,
      "successThreshold": 2,
      "timeout": 60000
    }
  },
  "supportsVoiceCloning": true,
  "supportsInstructionGen": true,
  "voiceCloningConfig": {
    "maxAudioSizeMb": 100,
    "supportedFormats": ["audio/wav", "audio/mpeg", "audio/x-m4a", "audio/flac"],
    "minDurationSec": 3,
    "maxDurationSec": 300,
    "supportsAsyncMode": true,
    "testPhrases": [
      "欢迎使用 Moss 声音克隆引擎，这是我的定制音色测试。",
      "Hello, this is a voice cloning test using the Moss engine."
    ]
  },
  "voiceGenerationConfig": {
    "model": "moss-voice-generator",
    "samplingDefaults": { "temperature": 1.5, "topP": 0.6, "topK": 50 },
    "supportedFormats": ["wav"],
    "testPhrases": [
      "这是一个指令生成音色的预览测试文本。",
      "This is a preview test for instruction-generated voice."
    ]
  }
}
