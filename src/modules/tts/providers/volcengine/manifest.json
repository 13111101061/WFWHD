{
  "$schema": "ProviderManifest/v2",
  "providerKey": "volcengine",
  "provider": {
    "displayName": "火山引擎",
    "description": "火山引擎语音合成服务",
    "status": "stable",
    "protocolTypes": [
      "http"
    ],
    "credentialMode": "accessKey"
  },
  "services": {
    "volcengine_http": {
      "displayName": "火山引擎 HTTP",
      "description": "火山引擎语音合成 HTTP 接口",
      "aliases": [
        "volcengine",
        "volcengine_http_legacy"
      ],
      "protocol": "http",
      "supportsStreaming": false,
      "supportsAsync": false,
      "apiStructure": "flat",
      "parameters": {
        "voice": {
          "status": "locked",
          "source": "providerVoiceId",
          "mapTo": "voice_type"
        },
        "text": {
          "status": "required",
          "mapTo": "text"
        },
        "speed": {
          "default": 1,
          "range": [
            0.5,
            2
          ],
          "mapTo": "speed_ratio"
        },
        "format": {
          "default": "mp3",
          "mapTo": "format"
        },
        "sampleRate": {
          "default": 24000,
          "mapTo": "sample_rate"
        }
      },
      "adapter": "./VolcengineTtsAdapter.js"
    }
  },
  "voiceCode": {
    "providerCode": "004",
    "serviceKey": "http"
  }
}