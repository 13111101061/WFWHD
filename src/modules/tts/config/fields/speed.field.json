{
  "$field": "speed",
  "key": "speed",
  "displayName": "语速",
  "description": "语音播放速度，1.0 为正常速度",
  "type": "number",
  "category": "audio",
  "required": false,
  "platformDefault": 1.0,
  "platformRange": { "min": 0.25, "max": 4.0 },
  "ui": {
    "group": "audio",
