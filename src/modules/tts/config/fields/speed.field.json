    "inputType": "slider",
    "step": 0.1,
    "labels": {
      "0.5": "慢",
      "1.0": "正常",
      "2.0": "快"
    }
  },
  "validation": {
    "range": { "min": 0.25, "max": 4.0 }
  }
}
