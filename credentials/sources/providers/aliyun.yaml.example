# 阿里云凭证配置示例
# 复制此文件为 aliyun.yaml 并配置您的凭证

meta:
  provider: aliyun
  name: 阿里云
  description: 阿里云智能语音服务
  # 选择策略: priority | round_robin | weighted
  selector: priority
  # 熔断器配置
  circuitBreaker:
    enabled: true
    failureThreshold: 5    # 连续失败次数阈值
    resetTimeout: 60000    # 熔断恢复时间 (ms)

requiredFields:
  - apiKey

accounts:
  # 主账号 - 高优先级
  - id: primary
    name: 主账号
    credentials:
      # 使用环境变量引用
      apiKey: ${ALIYUN_API_KEY:-${QWEN_API_KEY:-}}
    services:
      - cosyvoice
      - qwen_http
      - qwen_ws
    priority: 1
    weight: 3
    enabled: true
    metadata:
      description: 生产环境主账号
      tags: [production, primary]

  # 备用账号 - 低优先级（可选）
  # 取消注释以下配置以启用
  # - id: backup
  #   name: 备用账号
  #   credentials:
  #     apiKey: ${ALIYUN_API_KEY_BACKUP:-}
  #   services:
  #     - qwen_http
  #   priority: 2
  #   weight: 1
  #   enabled: true
  #   metadata:
  #     description: 备用账号
  #     tags: [backup]